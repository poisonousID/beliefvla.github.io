/* =========================================================
   BeliefVLA — Modern Research Project Page
   Refined, professional, contemporary styling
   ========================================================= */

:root {
    --bg: #0e0e10;            /* near-black (hero) */
    --bg-page: #fcfbfb;       /* warm near-white page */
    --bg-soft: #f5f3f3;
    --surface: #ffffff;

    --ink: #16161a;
    --ink-soft: #54515a;
    --ink-muted: #948f96;
    --border: #ececec;
    --border-strong: #dcd9d9;

    --accent: #d12027;        /* refined crimson */
    --accent-2: #f0484f;      /* lighter red highlight */
    --accent-soft: #fdecec;
    --accent-ink: #a8141a;

    --grad: linear-gradient(120deg, #e02630 0%, #c0151c 55%, #8e0f15 100%);

    --font-display: 'Space Grotesk', 'Inter', sans-serif;
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-mono: 'JetBrains Mono', ui-monospace, 'SFMono-Regular', Menlo, monospace;
    --font-mark: 'Impact', 'Haettenschweiler', 'Anton', 'Arial Narrow', sans-serif;

    --maxw: 1080px;
    --radius: 16px;
    --radius-sm: 10px;
    --shadow-sm: 0 1px 2px rgba(16, 24, 40, 0.05);
    --shadow-md: 0 8px 24px -8px rgba(16, 24, 40, 0.14);
    --shadow-lg: 0 24px 60px -20px rgba(20, 20, 22, 0.28);
}

* { box-sizing: border-box; }

html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
}

body {
    margin: 0;
    background-color: var(--bg-page);
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
}

a { color: var(--accent); text-decoration: none; transition: color 0.15s ease; }
a:hover { color: var(--accent-ink); }

.mono {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}

/* =========================================================
   Navigation
   ========================================================= */
.nav-bar {
    position: sticky;
    top: 0;
    width: 100%;
    background-color: rgba(251, 251, 253, 0.72);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
}

.nav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 14px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
}

/* Wordmark logo (matches the video) */
.wordmark {
    font-family: var(--font-mark);
    font-style: italic;
    font-weight: 400;
    display: inline-block;
    letter-spacing: 0.5px;
    line-height: 1;
}

.wordmark .b { color: var(--accent); }
.wordmark .v { color: var(--ink); font-style: normal; margin-left: 0.14em; }

.nav-logo { font-size: 1.7rem; }

/* VLA turns white on dark areas */
.hero .wordmark .v,
.site-footer .wordmark .v { color: #fff; }

.nav-links { display: flex; gap: 26px; }

.nav-links a {
    color: var(--ink-soft);
    font-size: 0.9rem;
    font-weight: 500;
    position: relative;
}

.nav-links a::after {
    content: "";
    position: absolute;
    left: 0; bottom: -4px;
    width: 0; height: 2px;
    background: var(--grad);
    border-radius: 2px;
    transition: width 0.2s ease;
}

.nav-links a:hover { color: var(--ink); }
.nav-links a:hover::after { width: 100%; }

.nav-icons { display: flex; gap: 8px; }

.nav-icons a {
    color: var(--ink-soft);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 7px 14px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    transition: all 0.18s ease;
}

.nav-icons a:hover {
    color: var(--ink);
    border-color: var(--accent);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
}

/* =========================================================
   Hero
   ========================================================= */
.hero {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: #fff;
    padding: 100px 28px 80px;
    text-align: center;
    isolation: isolate;
}

/* Animated gradient glows */
.hero::before,
.hero::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.55;
    z-index: -2;
}

.hero::before {
    width: 520px; height: 520px;
    background: radial-gradient(circle, #e02630, transparent 70%);
    top: -160px; left: -120px;
    animation: float1 14s ease-in-out infinite;
}

.hero::after {
    width: 460px; height: 460px;
    background: radial-gradient(circle, #7a0d12, transparent 70%);
    bottom: -180px; right: -100px;
    animation: float2 16s ease-in-out infinite;
}

/* Nine-grid montage backdrop (tiled) */
.hero-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: url('images/hero_montage.jpg') repeat top left;
    background-size: 25% auto;
    opacity: 0.14;
    filter: grayscale(0.2) brightness(0.6) contrast(1.05);
}

@keyframes float1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, 30px); }
}
@keyframes float2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-40px, -30px); }
}

.hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #f3d4d5;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 7px 16px;
    border-radius: 999px;
    margin-bottom: 30px;
    backdrop-filter: blur(6px);
}

.hero-badge .dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent-2);
    box-shadow: 0 0 0 4px rgba(240, 72, 79, 0.25);
}

.hero-title {
    display: block;
    font-size: 5.6rem;
    line-height: 1;
    margin: 0 0 24px 0;
    text-shadow: 0 4px 18px rgba(0, 0, 0, 0.45);
}

.hero-subtitle {
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.5;
    color: #b8b3b6;
    max-width: 680px;
    margin: 0 auto 34px auto;
}

.authors { font-size: 1.05rem; color: #ece8ea; margin-bottom: 4px; }
.affiliations { font-size: 0.95rem; color: #8a8388; margin-bottom: 40px; }

/* Buttons */
.action-buttons {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
}

.btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 0.97rem;
    font-weight: 600;
    padding: 13px 26px;
    border-radius: 999px;
    transition: all 0.2s ease;
}

.btn-primary {
    background: var(--grad);
    background-size: 160% 160%;
    color: #fff;
    border: none;
    box-shadow: 0 10px 30px -8px rgba(209, 32, 39, 0.55);
}

.btn-primary:hover {
    color: #fff;
    transform: translateY(-2px);
    background-position: 100% 0;
    box-shadow: 0 14px 36px -8px rgba(209, 32, 39, 0.7);
}

.btn-secondary {
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.18);
}

.btn-secondary:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.12);
    transform: translateY(-2px);
}

/* Scroll cue */
.scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 28px;
    z-index: 1;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #d9d4d6;
    font-size: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    animation: bob 1.8s ease-in-out infinite;
    transition: color 0.18s ease, background 0.18s ease, border-color 0.18s ease;
}

.scroll-cue:hover {
    color: #fff;
    background: var(--accent);
    border-color: var(--accent);
}

@keyframes bob {
    0%, 100% { transform: translate(-50%, 0); }
    50% { transform: translate(-50%, 7px); }
}

/* =========================================================
   Sections
   ========================================================= */
.section { padding: 84px 0; }
.alt-bg { background-color: var(--bg-soft); }

.container {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 28px;
}

.section-eyebrow {
    display: block;
    text-align: center;
    color: var(--accent);
    margin-bottom: 12px;
}

.section-heading {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 700;
    text-align: center;
    margin: 0 0 48px 0;
    letter-spacing: -1px;
}

.sub-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 0 18px 0;
    letter-spacing: -0.4px;
}

/* =========================================================
   Abstract
   ========================================================= */
.abstract-block {
    max-width: 760px;
    margin: 0 auto;
    text-align: justify;
    color: var(--ink-soft);
    font-size: 1.06rem;
}

.abstract-block p { margin: 0 0 18px 0; }
.abstract-block p:last-child { margin-bottom: 0; }
.abstract-block strong {
    color: var(--ink);
    font-weight: 600;
}

/* =========================================================
   Figure
   ========================================================= */
.figure { text-align: center; }

.figure-shell {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    box-shadow: var(--shadow-md);
    display: inline-block;
    max-width: 100%;
}

.figure-shell img {
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: var(--radius-sm);
}

.figure-caption {
    font-size: 0.9rem;
    color: var(--ink-muted);
    margin: 18px auto 0;
    max-width: none;
}

/* =========================================================
   Method cards
   ========================================================= */
.method-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 44px;
}

.method-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 26px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.method-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--grad);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
}

.method-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
}

.method-card:hover::before { transform: scaleX(1); }

.card-number {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
    background: var(--accent-soft);
    width: 38px; height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    margin-bottom: 18px;
}

.method-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 10px 0;
    color: var(--ink);
}

.method-card p {
    font-size: 0.96rem;
    color: var(--ink-soft);
    margin: 0;
}

/* =========================================================
   Stats
   ========================================================= */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-bottom: 56px;
}

.stat-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px 22px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.stat-box:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
}

.stat-value {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -1.5px;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.stat-label {
    font-weight: 600;
    font-size: 0.96rem;
    margin-top: 14px;
    color: var(--ink);
}

.stat-sub {
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin-top: 4px;
}

/* =========================================================
   Two column
   ========================================================= */
.grid-2-col {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 44px;
    align-items: center;
}

.mt-5 { margin-top: 52px; }

.feature-list { list-style: none; padding: 0; margin: 0; }

.feature-list li {
    position: relative;
    padding-left: 30px;
    margin-bottom: 14px;
    color: var(--ink-soft);
    font-size: 0.98rem;
}

.feature-list li::before {
    content: "\f00c";
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    position: absolute;
    left: 0; top: 0;
    font-size: 0.7rem;
    color: var(--accent);
    background: var(--accent-soft);
    width: 20px; height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
}

.feature-list strong { color: var(--ink); font-weight: 600; }

/* =========================================================
   Video
   ========================================================= */
.video-frame {
    position: relative;
    aspect-ratio: 16/9;
    background: #000;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
}

.main-video { width: 100%; height: 100%; display: block; object-fit: cover; }

.play-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(11,13,18,0.2), rgba(11,13,18,0.5));
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.3s ease;
    z-index: 5;
}

.play-btn {
    width: 84px; height: 84px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
}

.play-btn i {
    font-size: 1.9rem;
    margin-left: 5px;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
}

.video-frame:hover .play-btn { transform: scale(1.1); }

/* =========================================================
   Carousel
   ========================================================= */
.carousel-container {
    position: relative;
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    overflow: hidden;
    box-shadow: var(--shadow-md);
}

.carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -ms-overflow-style: none;
    scrollbar-width: none;
}

.carousel-track::-webkit-scrollbar { display: none; }

.carousel-card {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
}

.carousel-card img {
    width: 100%;
    height: 300px;
    object-fit: cover;
}

.panel-split { display: flex; height: 300px; }
.panel-split img { width: 50%; height: 100%; }
.panel-split img:first-child { border-right: 1px solid var(--border); }

.carousel-label {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    padding: 14px;
    color: var(--ink);
    border-top: 1px solid var(--border);
}

.nav-btn {
    position: absolute;
    top: calc(50% - 24px);
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink);
    border: 1px solid var(--border);
    width: 40px; height: 40px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.9rem;
    box-shadow: var(--shadow-md);
    transition: all 0.18s ease;
}

.nav-btn:hover {
    background: var(--grad);
    color: #fff;
    border-color: transparent;
}

.prev-btn { left: 14px; }
.next-btn { right: 14px; }

/* =========================================================
   Footer
   ========================================================= */
.site-footer {
    background: var(--bg-page);
    color: var(--ink-muted);
    padding: 30px 28px;
    text-align: center;
    font-size: 0.82rem;
    border-top: 1px solid var(--border);
}

.site-footer p { margin: 0; }

/* =========================================================
   Scroll reveal
   ========================================================= */
.reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
}

.reveal.in-view {
    opacity: 1;
    transform: none;
}

@media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
    .hero::before, .hero::after { animation: none; }
    .scroll-cue { animation: none; transform: translateX(-50%); }
}

/* =========================================================
   Responsive
   ========================================================= */
@media (max-width: 820px) {
    .grid-2-col, .method-grid, .stats-grid { grid-template-columns: 1fr; }
    .hero-title { font-size: 3.4rem; }
    .hero-subtitle { font-size: 1.1rem; }
    .hero { padding: 88px 24px 72px; }
    .section { padding: 60px 0; }
    .section-heading { font-size: 1.9rem; }
    .nav-links { display: none; }
}
